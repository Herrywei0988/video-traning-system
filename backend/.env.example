# ────────────────────────────────────────────────────────────
# 影片培訓整理系統 — 環境設定
# 請將此檔案複製為 .env 並填入正確的值
# cp .env.example .env
# ────────────────────────────────────────────────────────────

# ✅ 必填：OpenAI API Key（用於語音辨識與 AI 分析）
# 前往 https://platform.openai.com/api-keys 申請
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 選填：AI 模型（預設 gpt-4o-mini，也可用 gpt-4o 取得更好品質）
OPENAI_MODEL=gpt-4o-mini

# 選填：Server 監聽埠號（預設 8000）
PORT=8000
